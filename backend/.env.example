# Environment: development, production
ENV=development

# API Keys
BRAVE_API_KEY=your_brave_api_key
SERPAPI_API_KEY=your_serpapi_api_key
GEMINI_API_KEY=your_gemini_api_key

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/medisearch

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Headless Browser
HEADLESS_BROWSER_TYPE=playwright  # playwright or selenium
BROWSER_TIMEOUT=30000  # milliseconds

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=True
